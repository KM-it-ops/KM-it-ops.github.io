        ],
        "hex": "#eef3fb"
      }
    },
    "on-tertiary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.031,
          0.024,
          0.027
        ],
        "hex": "#080607"
      }
    },
    "on-signal": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.016,
          0.024,
          0.039
        ],
        "hex": "#04060a"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "section": {
      "$value": {
        "value": 88,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 14,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 20,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Space Grotesk",
        "fontSize": {
          "value": 4,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.045,
          "unit": "em"
        }
      }
    },
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Space Grotesk",
        "fontSize": {
          "value": 3,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.035,
          "unit": "em"
        }
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Space Grotesk",
        "fontSize": {
          "value": 1.75,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        }
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.92,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "label-caps": {
      "$type": "typography",
      "$value": {
        "fontFamily": "JetBrains Mono",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 0.08,
          "unit": "em"
        }
      }
    },
    "mono": {
      "$type": "typography",
      "$value": {
        "fontFamily": "JetBrains Mono",
        "fontSize": {
          "value": 0.88,
          "unit": "rem"
        },
        "fontWeight": 500
      }
    }
  }
