        ],
        "hex": "#ffb547"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.427,
          0.875,
          0.624
        ],
        "hex": "#6ddf9f"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.031,
